<script>
  // ----- Toggle documents (open in same tab, no external)
  const toggleBtns = document.querySelectorAll('.toggle-doc');
  toggleBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      const docId = this.getAttribute('data-doc');
      const contentDiv = document.getElementById(docId);
      if(contentDiv) {
        contentDiv.classList.toggle('show');
        this.textContent = contentDiv.classList.contains('show') ? 'Hide Document' : 'Read Document';
      }
    });
  });

  // Molar Mass Calculator
  const compoundMap = {
    "H2O": 18.015,
    "NaCl": 58.44,
    "CO2": 44.01,
    "C6H12O6": 180.16,
    "NaOH": 40.00
  };
  const calcBtn = document.getElementById('calcMolarBtn');
  const molarResult = document.getElementById('molarResult');
  if(calcBtn) {
    calcBtn.addEventListener('click', () => {
      const selected = document.getElementById('compoundSelect').value;
      const mass = compoundMap[selected];
      molarResult.innerText = `Molar Mass: ${mass} g/mol 🧪`;
    });
  }

  // pH Calculator
  const phBtn = document.getElementById('calcPhBtn');
  const phResult = document.getElementById('phResult');
  if(phBtn) {
    phBtn.addEventListener('click', () => {
      let conc = parseFloat(document.getElementById('hConcentration').value);
      if(isNaN(conc) || conc <= 0) {
        phResult.innerText = 'Please enter a valid positive concentration (e.g., 0.0001)';
        return;
      }
      let pH = -Math.log10(conc);
      phResult.innerText = `pH = ${pH.toFixed(2)} (${pH < 7 ? 'Acidic' : pH > 7 ? 'Basic' : 'Neutral'})`;
    });
  }

  // Periodic table first 20 elements data
  const elementsData = [
    {symbol:"H", name:"Hydrogen", atomic:1}, {symbol:"He", name:"Helium", atomic:2},
    {symbol:"Li", name:"Lithium", atomic:3}, {symbol:"Be", name:"Beryllium", atomic:4},
    {symbol:"B", name:"Boron", atomic:5}, {symbol:"C", name:"Carbon", atomic:6},
    {symbol:"N", name:"Nitrogen", atomic:7}, {symbol:"O", name:"Oxygen", atomic:8},
    {symbol:"F", name:"Fluorine", atomic:9}, {symbol:"Ne", name:"Neon", atomic:10},
    {symbol:"Na", name:"Sodium", atomic:11}, {symbol:"Mg", name:"Magnesium", atomic:12},
    {symbol:"Al", name:"Aluminium", atomic:13}, {symbol:"Si", name:"Silicon", atomic:14},
    {symbol:"P", name:"Phosphorus", atomic:15}, {symbol:"S", name:"Sulfur", atomic:16},
    {symbol:"Cl", name:"Chlorine", atomic:17}, {symbol:"Ar", name:"Argon", atomic:18},
    {symbol:"K", name:"Potassium", atomic:19}, {symbol:"Ca", name:"Calcium", atomic:20}
  ];
  const periodicContainer = document.getElementById('miniPeriodic');
  if(periodicContainer) {
    elementsData.forEach(el => {
      const elDiv = document.createElement('div');
      elDiv.classList.add('element');
      elDiv.innerText = el.symbol;
      elDiv.title = `${el.name} (${el.atomic})`;
      elDiv.addEventListener('click', () => {
        const infoDiv = document.getElementById('elementInfo');
        infoDiv.innerHTML = `✨ ${el.name} (${el.symbol}) | Atomic Number: ${el.atomic} | Category: ${el.atomic <=2 ? 'Noble Gas/Nonmetal' : 'Main group'}`;
      });
      periodicContainer.appendChild(elDiv);
    });
  }

